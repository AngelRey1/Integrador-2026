rules_version = '2';

// ============================================================
// REGLAS DE SEGURIDAD PARA SPORTCONNECT - PRODUCCIÓN
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===========================================
    // FUNCIONES AUXILIARES
    // ===========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Admin verificado por colección 'admins' o custom claim
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    // ===========================================
    // ADMINS
    // ===========================================
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      // Permitir crear si: es admin existente, O no hay ningún admin (bootstrap)
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ===========================================
    // USUARIOS (colección 'users')
    // ===========================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // USUARIOS (colección 'usuarios')
    // ===========================================
    match /usuarios/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // CLIENTES
    // ===========================================
    match /clientes/{clienteId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(clienteId);
      allow update: if isOwner(clienteId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // ENTRENADORES - Lectura pública
    // ===========================================
    match /entrenadores/{entrenadorId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // CLASES - Lectura pública
    // ===========================================
    match /clases/{claseId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.entrenadorId == request.auth.uid || isAdmin());
    }
    
    // ===========================================
    // DEPORTES - Lectura pública
    // ===========================================
    match /deportes/{deporteId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ===========================================
    // RESERVAS
    // ===========================================
    match /reservas/{reservaId} {
      // Permitir lectura pública para consultar horarios disponibles
      // (necesario para flujo de reserva sin login)
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.entrenadorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // ===========================================
    // PAGOS
    // ===========================================
    match /pagos/{pagoId} {
      allow read: if isAuthenticated() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.entrenadorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    // ===========================================
    // RESEÑAS - Lectura pública
    // ===========================================
    match /resenas/{resenaId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.clienteId == request.auth.uid || isAdmin());
    }
    
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.clienteId == request.auth.uid || isAdmin());
    }
    
    // ===========================================
    // CONVERSACIONES
    // ===========================================
    match /conversaciones/{conversacionId} {
      allow read: if isAuthenticated() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.entrenadorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.entrenadorId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /mensajes/{mensajeId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // ===========================================
    // CONVERSACIONES ADMIN (Chat entre admin y entrenadores)
    // ===========================================
    // Nota: Para funcionar con queries, permitimos lectura a usuarios autenticados
    // La seguridad viene del panel admin que solo admins pueden acceder
    match /conversacionesAdmin/{conversacionId} {
      // Lectura permitida a usuarios autenticados
      // El entrenador ve solo sus conversaciones (filtrado en código)
      // El admin ve todas (filtrado en código del panel admin)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      match /mensajes/{mensajeId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // ===========================================
    // NOTIFICACIONES
    // ===========================================
    match /notificaciones/{notificacionId} {
      allow read: if isAuthenticated() && 
        resource.data.usuarioId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        resource.data.usuarioId == request.auth.uid;
    }
    
    // ===========================================
    // SOLICITUDES ENTRENADOR
    // ===========================================
    match /solicitudesEntrenador/{solicitudId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // ===========================================
    // CONFIGURACIÓN - Lectura pública
    // ===========================================
    match /configuracion/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ===========================================
    // REPORTES - Solo admin
    // ===========================================
    match /reportes/{reporteId} {
      allow read, write: if isAdmin();
    }
    // ===========================================
    // PAGOS SUSCRIPCIONES - Comprobantes Fase 5
    // ===========================================
    match /pagos_suscripciones/{pagoId} {
      // El entrenador puede crear su propia solicitud y leer la suya
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        resource.data.entrenadorId == request.auth.uid ||
        isAdmin()
      );
      // Solo admin puede aprobar o rechazar (actualizar estado)
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
